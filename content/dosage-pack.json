    "body": {
      "type": "numeric",
      "problem": "Order: 500 mL D5W over 4 hours. Drop factor: 20 gtts/mL. Calculate the drip rate in gtts/min. (Round to nearest whole number.)",
      "answer": 42,
      "unit": "gtts/min",
      "tolerance": 0,
      "workingSteps": [
        "Drip rate = (Volume × Drop factor) ÷ Time in minutes",
        "Time: 4 hr × 60 min/hr = 240 min",
        "(500 mL × 20 gtts/mL) ÷ 240 min = 10,000 ÷ 240 = 41.67 ≈ 42 gtts/min"
      ]
    },
