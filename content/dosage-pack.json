    "body": {
      "type": "numeric",
      "problem": "The order reads: amoxicillin 375 mg PO. Available: amoxicillin 250 mg/5 mL suspension. How many mL should you administer?",
      "answer": 7.5,
      "unit": "mL",
      "tolerance": 0,
      "workingSteps": [
        "Desired dose ÷ Available dose per volume = volume",
        "375 mg ÷ (250 mg / 5 mL) = 375 mg × (5 mL / 250 mg) = 7.5 mL"
      ]
    },
